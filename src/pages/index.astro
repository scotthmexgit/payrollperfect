---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZohoFormEmbed from '../components/forms/ZohoFormEmbed.astro';
import ZohoFormLightbox from '../components/forms/ZohoFormLightbox.astro';
---

<BaseLayout
  title="Payroll Perfect — Reliable Payroll for Utah Businesses"
  description="Professional payroll services in South Jordan, Utah since 1999. Payroll processing, tax filing, direct deposit, and compliance."
>

  <!-- ===== HERO ===== -->
  <section style="
    position: relative;
    overflow: hidden;
    padding: 96px 24px 80px;
    background-color: var(--color-cream);
  ">
    <!-- Background orbital rings (atmospheric) -->
    <div style="
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      pointer-events: none;
      overflow: hidden;
    " aria-hidden="true">
      <svg width="800" height="800" viewBox="0 0 800 800"
           style="opacity: 0.04; transform: translate(15%, -10%);">
        <ellipse cx="400" cy="400" rx="380" ry="170" stroke="#1c3561" fill="none" stroke-width="1.5" transform="rotate(-15, 400, 400)"/>
        <ellipse cx="400" cy="400" rx="280" ry="125" stroke="#1c3561" fill="none" stroke-width="1.5" transform="rotate(-15, 400, 400)"/>
        <ellipse cx="400" cy="400" rx="180" ry="80"  stroke="#1c3561" fill="none" stroke-width="1"   transform="rotate(-15, 400, 400)"/>
        <ellipse cx="400" cy="400" rx="80"  cy="400" ry="36"  stroke="#1c3561" fill="none" stroke-width="1"   transform="rotate(-15, 400, 400)"/>
        <circle cx="400" cy="400" r="16" fill="#1c3561"/>
      </svg>
    </div>

    <div style="
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: 64px;
      align-items: center;
    " class="hero-grid">

      <!-- Left: copy -->
      <div>
        <p class="animate-fade-up delay-100" style="
          font-size: 12px;
          font-weight: 600;
          letter-spacing: 0.12em;
          text-transform: uppercase;
          color: var(--color-muted);
          margin: 0 0 20px;
        ">
          South Jordan, Utah &middot; Since 1999
        </p>

        <h1 class="font-display animate-fade-up delay-200" style="
          font-size: clamp(40px, 5vw, 64px);
          font-weight: 700;
          line-height: 1.08;
          color: var(--color-navy);
          margin: 0 0 24px;
          font-optical-sizing: auto;
        ">
          Payroll that just <em class="not-italic" style="color: var(--color-orange);">works.</em>
        </h1>

        <p class="animate-fade-up delay-300" style="
          font-size: 20px;
          line-height: 1.6;
          color: var(--color-muted);
          margin: 0 0 40px;
          max-width: 520px;
        ">
          Reliable payroll services for Utah businesses. We handle the
          paperwork, filings, and compliance&nbsp;&mdash; you focus on your business.
        </p>

        <div class="animate-fade-up delay-400" style="display: flex; gap: 16px; flex-wrap: wrap;">
          <ZohoFormLightbox buttonText="Get a quote" />
          <a href="tel:+18014469888" style="
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 52px;
            padding: 0 32px;
            background: transparent;
            color: var(--color-navy);
            border: 2px solid var(--color-navy);
            border-radius: 8px;
            font-family: 'Geist', sans-serif;
            font-size: 15px;
            font-weight: 600;
            text-decoration: none;
            transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease, color 0.15s ease;
          "
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(28,53,97,0.15)'; this.style.backgroundColor='var(--color-navy)'; this.style.color='var(--color-cream)';"
          onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.backgroundColor='transparent'; this.style.color='var(--color-navy)';">
            Call (801)&nbsp;446-9888
          </a>
        </div>
      </div>

      <!-- Right: orbital visual -->
      <div style="display: flex; align-items: center; justify-content: center;" class="hero-visual">
        <svg viewBox="0 0 480 480" width="480" height="480" style="max-width: 100%; height: auto;" aria-hidden="true">
          <!-- Slow-rotating outer ring group -->
          <g class="animate-orbit" style="transform-origin: 240px 240px;">
            <ellipse cx="240" cy="240" rx="220" ry="98" stroke="#1c3561" fill="none" stroke-width="1.5" transform="rotate(-18, 240, 240)" opacity="0.25"/>
            <!-- Orbital dot on outer ring -->
            <ellipse cx="240" cy="240" rx="220" ry="98" fill="none" transform="rotate(-18, 240, 240)" id="orbit-path-outer"/>
          </g>

          <!-- Static inner rings -->
          <ellipse cx="240" cy="240" rx="158" ry="70" stroke="#c85a1e" fill="none" stroke-width="1.5" transform="rotate(-18, 240, 240)" opacity="0.4"/>
          <ellipse cx="240" cy="240" rx="96"  ry="42"  stroke="#1c3561" fill="none" stroke-width="1"   transform="rotate(-18, 240, 240)" opacity="0.2"/>

          <!-- Center mass -->
          <circle cx="240" cy="240" r="18" fill="#1c3561" opacity="0.85"/>
          <circle cx="240" cy="240" r="8"  fill="#c85a1e"/>

          <!-- Accent dot on middle ring -->
          <circle cx="398" cy="240" r="7" fill="#c85a1e" opacity="0.9" transform="rotate(-18, 240, 240)"/>

          <!-- Small dot on inner ring -->
          <circle cx="336" cy="240" r="4" fill="#1c3561" opacity="0.5" transform="rotate(110, 240, 240)"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ===== VALUE PROPS ===== -->
  <section style="
    background-color: var(--color-white);
    padding: 96px 24px;
  ">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="font-display" style="
        font-size: clamp(32px, 3.5vw, 40px);
        font-weight: 600;
        color: var(--color-navy);
        text-align: center;
        margin: 0 0 64px;
        font-optical-sizing: auto;
      ">
        Why Payroll Perfect
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
      " class="cards-grid">

        <!-- Card 1: Reliable (teal icon) -->
        <div style="
          background: var(--color-cream);
          border-radius: 12px;
          padding: 36px 32px;
          border-left: 4px solid var(--color-navy);
          box-shadow: 0 4px 24px rgba(28, 53, 97, 0.08);
        ">
          <svg width="48" height="48" viewBox="0 0 48 48" style="margin-bottom: 20px;" aria-hidden="true">
            <circle cx="24" cy="24" r="20" stroke="#2A9D8F" fill="none" stroke-width="2" opacity="0.4"/>
            <circle cx="24" cy="24" r="12" stroke="#2A9D8F" fill="none" stroke-width="1.5" opacity="0.6"/>
            <circle cx="24" cy="24" r="3"  fill="#2A9D8F"/>
            <circle cx="44" cy="24" r="3"  fill="#2A9D8F" opacity="0.7"/>
          </svg>
          <h3 class="font-display" style="font-size: 22px; font-weight: 600; color: var(--color-navy); margin: 0 0 12px;">Reliable</h3>
          <p style="font-size: 15px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            25 years in business. Steady service through every tax season.
          </p>
        </div>

        <!-- Card 2: Local (orange icon) -->
        <div style="
          background: var(--color-cream);
          border-radius: 12px;
          padding: 36px 32px;
          border-left: 4px solid var(--color-navy);
          box-shadow: 0 4px 24px rgba(28, 53, 97, 0.08);
        ">
          <svg width="48" height="48" viewBox="0 0 48 48" style="margin-bottom: 20px;" aria-hidden="true">
            <circle cx="24" cy="20" r="10" stroke="#c85a1e" fill="none" stroke-width="2"/>
            <circle cx="24" cy="20" r="4" fill="#c85a1e" opacity="0.7"/>
            <path d="M24 30 C16 36 10 42 24 46 C38 42 32 36 24 30Z" fill="#c85a1e" opacity="0.25"/>
          </svg>
          <h3 class="font-display" style="font-size: 22px; font-weight: 600; color: var(--color-navy); margin: 0 0 12px;">Local</h3>
          <p style="font-size: 15px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Based in South Jordan. We know Utah payroll law because it&rsquo;s our law too.
          </p>
        </div>

        <!-- Card 3: Comprehensive (navy icon) -->
        <div style="
          background: var(--color-cream);
          border-radius: 12px;
          padding: 36px 32px;
          border-left: 4px solid var(--color-navy);
          box-shadow: 0 4px 24px rgba(28, 53, 97, 0.08);
        ">
          <svg width="48" height="48" viewBox="0 0 48 48" style="margin-bottom: 20px;" aria-hidden="true">
            <rect x="8"  y="10" width="32" height="6"  rx="2" fill="#1c3561" opacity="0.7"/>
            <rect x="8"  y="21" width="24" height="6"  rx="2" fill="#1c3561" opacity="0.5"/>
            <rect x="8"  y="32" width="28" height="6"  rx="2" fill="#1c3561" opacity="0.3"/>
          </svg>
          <h3 class="font-display" style="font-size: 22px; font-weight: 600; color: var(--color-navy); margin: 0 0 12px;">Comprehensive</h3>
          <p style="font-size: 15px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Full-service: payroll, tax filing, reporting, HR compliance &mdash; one team.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section style="
    background-color: var(--color-cream);
    padding: 96px 24px;
  ">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="font-display" style="
        font-size: clamp(32px, 3.5vw, 40px);
        font-weight: 600;
        color: var(--color-navy);
        text-align: center;
        margin: 0 0 64px;
        font-optical-sizing: auto;
      ">
        What we handle
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 48px;
      " class="services-grid">

        <div style="
          background: var(--color-white);
          border-radius: 10px;
          padding: 32px;
          box-shadow: 0 2px 12px rgba(28,53,97,0.06);
        ">
          <h3 style="font-size: 18px; font-weight: 600; color: var(--color-navy); margin: 0 0 10px;">Payroll processing</h3>
          <p style="font-size: 14px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Accurate, on-time payroll runs for businesses of any size. Direct deposit or check — your choice.
          </p>
        </div>

        <div style="
          background: var(--color-white);
          border-radius: 10px;
          padding: 32px;
          box-shadow: 0 2px 12px rgba(28,53,97,0.06);
        ">
          <h3 style="font-size: 18px; font-weight: 600; color: var(--color-navy); margin: 0 0 10px;">Tax filing &amp; compliance</h3>
          <p style="font-size: 14px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Federal and state payroll tax deposits, quarterly filings, and year-end W-2s handled for you.
          </p>
        </div>

        <div style="
          background: var(--color-white);
          border-radius: 10px;
          padding: 32px;
          box-shadow: 0 2px 12px rgba(28,53,97,0.06);
        ">
          <h3 style="font-size: 18px; font-weight: 600; color: var(--color-navy); margin: 0 0 10px;">Direct deposit &amp; check services</h3>
          <p style="font-size: 14px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Flexible disbursement options. Same-day ACH available for qualifying clients.
          </p>
        </div>

        <div style="
          background: var(--color-white);
          border-radius: 10px;
          padding: 32px;
          box-shadow: 0 2px 12px rgba(28,53,97,0.06);
        ">
          <h3 style="font-size: 18px; font-weight: 600; color: var(--color-navy); margin: 0 0 10px;">Reporting &amp; analytics</h3>
          <p style="font-size: 14px; line-height: 1.7; color: var(--color-muted); margin: 0;">
            Clear payroll summaries, labor cost breakdowns, and audit-ready records on demand.
          </p>
        </div>

      </div>

      <div style="text-align: center;">
        <a href="/services" style="
          font-size: 15px;
          font-weight: 600;
          color: var(--color-orange);
          text-decoration: none;
          transition: color 0.15s ease;
        " onmouseover="this.style.color='var(--color-orange-bright)'" onmouseout="this.style.color='var(--color-orange)'">
          See all services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ===== PORTAL STRIP ===== -->
  <section style="
    background-color: var(--color-white);
    border-top: 1px solid var(--color-orange);
    padding: 80px 24px;
  ">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="font-display" style="
        font-size: clamp(26px, 3vw, 32px);
        font-weight: 600;
        color: var(--color-navy);
        text-align: center;
        margin: 0 0 48px;
        font-optical-sizing: auto;
      ">
        Client resources
      </h2>

      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      " class="portals-grid">

        <a href="https://ppx.payrollperfect.com" target="_blank" rel="noopener noreferrer" style="
          display: block;
          background: var(--color-white);
          border: 1px solid rgba(28,53,97,0.15);
          border-radius: 10px;
          padding: 28px 24px;
          text-decoration: none;
          transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
          position: relative;
          overflow: hidden;
        "
        onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-orange)'; this.style.boxShadow='0 8px 24px rgba(200,90,30,0.12)';"
        onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(28,53,97,0.15)'; this.style.boxShadow='none';">
          <h3 style="font-size: 16px; font-weight: 700; color: var(--color-navy); margin: 0 0 6px;">PPX</h3>
          <p style="font-size: 15px; font-weight: 600; color: var(--color-navy); margin: 0 0 8px;">Employer Portal</p>
          <p style="font-size: 13px; color: var(--color-muted); margin: 0;">Run payroll and manage your account</p>
        </a>

        <a href="https://payrollperfect.myfileguardian.com" target="_blank" rel="noopener noreferrer" style="
          display: block;
          background: var(--color-white);
          border: 1px solid rgba(28,53,97,0.15);
          border-radius: 10px;
          padding: 28px 24px;
          text-decoration: none;
          transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        "
        onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-orange)'; this.style.boxShadow='0 8px 24px rgba(200,90,30,0.12)';"
        onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(28,53,97,0.15)'; this.style.boxShadow='none';">
          <h3 style="font-size: 16px; font-weight: 700; color: var(--color-navy); margin: 0 0 6px;">File Guardian</h3>
          <p style="font-size: 15px; font-weight: 600; color: var(--color-navy); margin: 0 0 8px;">Document Portal</p>
          <p style="font-size: 13px; color: var(--color-muted); margin: 0;">Secure document exchange</p>
        </a>

        <a href="https://ex.payrollperfect.com" target="_blank" rel="noopener noreferrer" style="
          display: block;
          background: var(--color-white);
          border: 1px solid rgba(28,53,97,0.15);
          border-radius: 10px;
          padding: 28px 24px;
          text-decoration: none;
          transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        "
        onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='var(--color-orange)'; this.style.boxShadow='0 8px 24px rgba(200,90,30,0.12)';"
        onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(28,53,97,0.15)'; this.style.boxShadow='none';">
          <h3 style="font-size: 16px; font-weight: 700; color: var(--color-navy); margin: 0 0 6px;">EX</h3>
          <p style="font-size: 15px; font-weight: 600; color: var(--color-navy); margin: 0 0 8px;">New Employee Portal</p>
          <p style="font-size: 13px; color: var(--color-muted); margin: 0;">Employee onboarding and self-service</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ===== CONTACT STRIP ===== -->
  <section style="
    background-color: var(--color-cream);
    padding: 96px 24px;
  ">
    <div style="
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 64px;
      align-items: start;
    " class="contact-grid">

      <!-- Left: contact info -->
      <div>
        <h2 class="font-display" style="
          font-size: clamp(26px, 3vw, 32px);
          font-weight: 600;
          color: var(--color-navy);
          margin: 0 0 32px;
          font-optical-sizing: auto;
        ">
          Get in touch
        </h2>

        <address style="font-style: normal; display: flex; flex-direction: column; gap: 20px;">
          <div>
            <p style="font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); margin: 0 0 6px;">Address</p>
            <p style="font-size: 15px; line-height: 1.6; color: var(--color-ink); margin: 0;">
              1206 W South Jordan Pkwy, Ste A<br />
              South Jordan, UT 84095
            </p>
          </div>

          <div>
            <p style="font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); margin: 0 0 6px;">Phone</p>
            <a href="tel:+18014469888" style="
              font-size: 20px;
              font-weight: 600;
              color: var(--color-orange);
              text-decoration: none;
              transition: color 0.15s ease;
            " onmouseover="this.style.color='var(--color-orange-bright)'" onmouseout="this.style.color='var(--color-orange)'">
              (801) 446-9888
            </a>
          </div>

          <div>
            <p style="font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); margin: 0 0 6px;">Hours</p>
            <table style="font-size: 14px; color: var(--color-ink); border-collapse: collapse;">
              <tr><td style="padding: 2px 16px 2px 0; white-space: nowrap;">Mon&ndash;Thu</td><td>8:30 AM &ndash; 5:00 PM</td></tr>
              <tr><td style="padding: 2px 16px 2px 0;">Fri</td><td>8:30 AM &ndash; 2:30 PM</td></tr>
              <tr><td style="padding: 2px 16px 2px 0; color: var(--color-muted);">Sat&ndash;Sun</td><td style="color: var(--color-muted);">Closed</td></tr>
            </table>
          </div>
        </address>
      </div>

      <!-- Right: form placeholder -->
      <div>
        <ZohoFormEmbed />
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 767px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
    }
    .hero-visual {
      display: none !important;
    }
    .cards-grid {
      grid-template-columns: 1fr !important;
    }
    .services-grid {
      grid-template-columns: 1fr !important;
    }
    .portals-grid {
      grid-template-columns: 1fr !important;
    }
    .contact-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
