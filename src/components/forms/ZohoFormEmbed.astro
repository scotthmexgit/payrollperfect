---
interface Props {
  formUrl?: string;
}

const { formUrl } = Astro.props;
const isPlaceholder = !formUrl || formUrl === 'PLACEHOLDER';
---

{isPlaceholder ? (
  <div style="
    background-color: var(--color-cream);
    border: 1px dashed rgba(28, 53, 97, 0.2);
    border-radius: 12px;
    padding: 32px;
    min-height: 520px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  ">
    <p style="
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin: 0 0 8px;
    ">
      Form Placeholder — Zoho Contact Form will render here
    </p>

    <!-- Name -->
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <div style="height: 12px; width: 48px; background: rgba(28,53,97,0.12); border-radius: 4px;"></div>
      <div style="height: 40px; background: rgba(28,53,97,0.06); border: 1px solid rgba(28,53,97,0.15); border-radius: 6px;"></div>
    </div>

    <!-- Email -->
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <div style="height: 12px; width: 40px; background: rgba(28,53,97,0.12); border-radius: 4px;"></div>
      <div style="height: 40px; background: rgba(28,53,97,0.06); border: 1px solid rgba(28,53,97,0.15); border-radius: 6px;"></div>
    </div>

    <!-- Phone -->
    <div style="display: flex; flex-direction: column; gap: 6px;">
      <div style="height: 12px; width: 44px; background: rgba(28,53,97,0.12); border-radius: 4px;"></div>
      <div style="height: 40px; background: rgba(28,53,97,0.06); border: 1px solid rgba(28,53,97,0.15); border-radius: 6px;"></div>
    </div>

    <!-- Message -->
    <div style="display: flex; flex-direction: column; gap: 6px; flex: 1;">
      <div style="height: 12px; width: 56px; background: rgba(28,53,97,0.12); border-radius: 4px;"></div>
      <div style="height: 112px; background: rgba(28,53,97,0.06); border: 1px solid rgba(28,53,97,0.15); border-radius: 6px;"></div>
    </div>

    <!-- Submit -->
    <button disabled style="
      height: 44px;
      background-color: var(--color-orange);
      color: var(--color-white);
      border: none;
      border-radius: 6px;
      font-family: 'Geist', sans-serif;
      font-size: 15px;
      font-weight: 600;
      cursor: not-allowed;
      opacity: 0.6;
      width: 100%;
    ">
      Send
    </button>
  </div>
) : (
  <div id="zoho-form-embed">
    {/* TODO: Wire real Zoho JS embed snippet here once operator provides formUrl */}
    {/* Pattern per ADR-0003: script tag creates auto-resizing iframe via postMessage */}
    {/* formUrl = {formUrl} */}
    <p style="color: var(--color-muted); font-size: 14px;">Form loading...</p>
  </div>
)}
